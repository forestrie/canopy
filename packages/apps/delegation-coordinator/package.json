{
  "name": "@canopy/delegation-coordinator",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "doppler run --project canopy --config dev -- sh -c 'exec wrangler dev --env dev --inspector-port 9234 --var COORDINATOR_APP_TOKEN:${COORDINATOR_APP_TOKEN} --var CUSTODIAN_APP_TOKEN:${CUSTODIAN_APP_TOKEN} --var CUSTODIAN_URL:${CUSTODIAN_URL}'",
    "build": "tsc --noEmit && wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env prod",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:debug": "vitest --inspect --no-file-parallelism",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@forestrie/delegation-cose": "workspace:*",
    "@forestrie/encoding": "workspace:*",
    "@canopy/webhook-url": "workspace:*",
    "@canopy/forestrie-sharding": "workspace:*",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.7.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.13",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@forestrie/encoding": "workspace:*",
    "@forestrie/receipt-verify": "workspace:*",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.94.0"
  }
}
