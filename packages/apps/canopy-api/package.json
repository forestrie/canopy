{
  "name": "@canopy/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit && wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:bootstrap-grant": "vitest run test/bootstrap-grant.test.ts",
    "test:debug": "vitest --inspect --no-file-parallelism",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@canopy/encoding": "workspace:*",
    "@canopy/forestrie-ingress-types": "workspace:*",
    "@canopy/forestrie-sharding": "workspace:*",
    "@canopy/merklelog": "workspace:*",
    "@canopy/x402-settlement-types": "workspace:*",
    "@x402/core": "^2.1.0",
    "@x402/evm": "^2.1.0",
    "cbor-x": "^1.5.9",
    "cose-js": "^0.9.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.13",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.43.0"
  }
}
