{
  "name": "@forestrie/canopy-e2e-kit",
  "version": "0.4.0",
  "type": "module",
  "description": "Reusable Playwright e2e helpers for canopy system tests (ARC-0024 Layer 1)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "peerDependencies": {
    "@playwright/test": "^1.48.0",
    "viem": "^2.21.0"
  },
  "dependencies": {
    "@forestrie/delegation-cose": "workspace:^",
    "@forestrie/encoding": "workspace:*",
    "@forestrie/grant-builder": "workspace:*",
    "@forestrie/receipt-verify": "workspace:*",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.7.1",
    "cbor-x": "^1.5.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.9.2",
    "viem": "^2.21.0",
    "vitest": "^3.2.4"
  }
}
