{
  "name": "@canopy/api-e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest --run tests/utils/byok-delegation-cbor.test.ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "pnpm exec playwright test --project=integration --project=system --project=custodian",
    "test:e2e:integration": "pnpm exec playwright test --project=integration",
    "test:e2e:system": "pnpm exec playwright test --project=system",
    "test:e2e:custodian": "pnpm exec playwright test --project=custodian",
    "test:e2e:coordinator": "pnpm exec playwright test --project=coordinator",
    "test:e2e:prod": "pnpm exec playwright test --project=prod"
  },
  "dependencies": {
    "@canopy/api": "workspace:*",
    "@canopy/encoding": "workspace:*",
    "cbor-x": "^1.5.9",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
