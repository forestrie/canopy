{
  "name": "@forestrie/receipt-verify",
  "version": "0.8.1",
  "license": "MIT",
  "type": "module",
  "description": "Offline SCITT grant receipt verification (ADR-0045)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forestrie/canopy.git",
    "directory": "packages/libs/receipt-verify"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "check:browser-safe": "node tools/check-browser-safe.mjs",
    "test": "pnpm run check:browser-safe && vitest --run",
    "test:watch": "vitest",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@forestrie/encoding": "workspace:*",
    "@forestrie/merklelog": "workspace:*",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
